{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ES2020",
    "rootDir": "./typescript",
    "outDir": "./public/javascript",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "typescript/**/*.ts"
  ]
}